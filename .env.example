# Django secret key. Required when DEBUG=0; use a unique generated value in production.
SECRET_KEY=replace-with-a-long-random-secret-key

# Comma-separated mailbox-encryption salt keys. Rotate by prepending a new value, re-saving mailbox passwords, then removing retired keys.
FERNET_KEYS=example-fernet-salt-20260425-9b1f6e7c8a4d2f0e5c3b7a9d1e6f8c2b

# Debug mode. Defaults to 0 in settings; set to 1 only for local development.
DEBUG=0

# Comma-separated hostnames allowed to serve the app. Required when DEBUG=0.
ALLOWED_HOSTS=example.com,www.example.com

# Comma-separated trusted HTTPS origins for CSRF. Required when DEBUG=0.
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Database backend selector. The app supports PostgreSQL only.
DATABASE_ENGINE=postgres

# PostgreSQL database name.
POSTGRES_DB=perfumex

# PostgreSQL username.
POSTGRES_USER=perfumex

# PostgreSQL password.
POSTGRES_PASSWORD=replace-with-database-password

# PostgreSQL host.
POSTGRES_HOST=127.0.0.1

# PostgreSQL port.
POSTGRES_PORT=5432

# Enable OpenAI-backed assistant features when configured.
ASSISTANT_USE_OPENAI=false

# Model used for lightweight assistant suggestions.
OPENAI_MODEL_SUGGESTION=gpt-5.4-mini

# Model used for assistant research flows.
OPENAI_MODEL_RESEARCH=gpt-5.4

# Model used for assistant writing flows.
OPENAI_MODEL_WRITER=gpt-5.4-mini
